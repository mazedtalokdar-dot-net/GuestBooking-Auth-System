@model IEnumerable<_1291163_MVC_EF_Project.Models.Guest>

@{
    ViewBag.Title = "Guests";
}

<h2>Guests</h2>

<p>
    @Html.ActionLink("Create Guest", "Create", null, new { @class = "btn btn-primary" })
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Photo</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var g in Model)
        {
            <tr>
                <td>@g.FullName</td>
                <td>@g.Phone</td>
                <td>@g.Email</td>
                <td>
                    @if (!string.IsNullOrEmpty(g.PhotoPath))
                    {
                        <img src="@g.PhotoPath" style="height:50px;width:50px;object-fit:cover;border-radius:6px;" />
                    }
                    else
                    { <span>N/A</span>}
                </td>
                <td>
                    @Html.ActionLink("Edit", "Edit", new { id = g.GuestId }, new { @class = "btn btn-warning btn-sm" })
                    @Html.ActionLink("Delete", "Delete", new { id = g.GuestId }, new { @class = "btn btn-danger btn-sm" })
                </td>
            </tr>
        }
    </tbody>
</table>
